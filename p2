#include <iostream>
using namespace std;
float simpleInterest(float p, float r = 5, float t = 1) {
    return (p * r * t) / 100;
}
int main() {
    float principal;
    cout << "Enter Principal Amount: ";
    cin >> principal;
    cout << "Simple Interest (default rate and time): "
         << simpleInterest(principal) << endl;
    cout << "Simple Interest (rate = 10, default time): "
         << simpleInterest(principal, 10) << endl;
    cout << "Simple Interest (rate = 10, time = 2): "
         << simpleInterest(principal, 10, 2) << endl;
     return 0;
}
